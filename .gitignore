# Never commit secrets / materialized env files.
# Non-secret config belongs in compose.yaml; secrets go in the Komodo Stack UI.
# (Komodo writes env files like .env / .env.production into the run dir at deploy time.)
.env
*.env
.env.*
**/.env
**/.env.*
secrets/
.claude/

# Local, secret-bearing config copies kept off git. The authoritative copy also lives on the host
# under /srv (backed up there); this pattern lets a working copy sit next to its compose, e.g.
# stacks/plex/kometa-config.local.yml (Plex token + TMDb key).
*.local.yml
*.local.yaml
