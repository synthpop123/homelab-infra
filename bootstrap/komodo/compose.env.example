####################################
# 🦎 KOMODO COMPOSE - VARIABLES 🦎 #
####################################
#
# Bootstrap env for the Komodo deployment itself (see ./README.md).
# Copy to `compose.env` on the host and fill in the secrets — the real
# `compose.env` is git-ignored (`*.env`), so values never get committed.
#
# Non-secret values below mirror the live Famesystems deploy; every secret is a
# `__CHANGE_ME__` placeholder. Full reference (all options + docs):
#   https://github.com/moghtech/komodo/blob/main/compose/compose.env

## Image tag — pinned to the major line, like every stack (Renovate-friendly).
COMPOSE_KOMODO_IMAGE_TAG="2"
## Dated DB backups on the host — see ../../docs/backup-restore.md
COMPOSE_KOMODO_BACKUPS_PATH=/etc/komodo/backups

## MongoDB root credentials (DB is internal-only; still use a strong password).
KOMODO_DATABASE_USERNAME=komodo
KOMODO_DATABASE_PASSWORD=__CHANGE_ME__

## Time zone for schedules.
TZ=Asia/Shanghai

#=-------------------------=#
#= Komodo Core Environment =#
#=-------------------------=#

## Public URL (used for OAuth / webhook URL suggestions) + browser-tab title.
KOMODO_HOST=https://komodo.lkwplus.com
KOMODO_TITLE=Komodo

## Core <-> Periphery auth uses the keypair in the `komodo_keys` volume (not a passkey).
KOMODO_PERIPHERY_PUBLIC_KEY=file:/config/keys/periphery.pub

## Local username/password login + the first-run admin account.
KOMODO_LOCAL_AUTH=true
KOMODO_INIT_ADMIN_USERNAME=lkw123
KOMODO_INIT_ADMIN_PASSWORD=__CHANGE_ME__

## First Server created on launch — must match PERIPHERY_CONNECT_AS below.
KOMODO_FIRST_SERVER_NAME=Famesystems

KOMODO_DISABLE_CONFIRM_DIALOG=false
KOMODO_DISABLE_INIT_RESOURCES=false

## Incoming-webhook auth + JWT signing (generate long random strings).
KOMODO_WEBHOOK_SECRET=__CHANGE_ME__
KOMODO_JWT_SECRET=__CHANGE_ME__
KOMODO_JWT_TTL="1-day"

## Polling intervals.
KOMODO_MONITORING_INTERVAL="15-sec"
KOMODO_RESOURCE_POLL_INTERVAL="1-hr"

## Lock down signups / non-admin creation.
KOMODO_DISABLE_USER_REGISTRATION=true
KOMODO_ENABLE_NEW_USERS=false
KOMODO_DISABLE_NON_ADMIN_CREATE=false
KOMODO_TRANSPARENT_MODE=false

## OAuth / OIDC disabled (see upstream compose.env for the full option list).
KOMODO_OIDC_ENABLED=false
KOMODO_GITHUB_OAUTH_ENABLED=false
KOMODO_GOOGLE_OAUTH_ENABLED=false

KOMODO_LOGGING_PRETTY=false
KOMODO_PRETTY_STARTUP_CONFIG=false

#=------------------------------=#
#= Komodo Periphery Environment =#
#=------------------------------=#

PERIPHERY_CORE_ADDRESS=ws://core:9120
PERIPHERY_CONNECT_AS=${KOMODO_FIRST_SERVER_NAME}
PERIPHERY_CORE_PUBLIC_KEYS=file:/config/keys/core.pub
## Agent root — all compose files / repos Periphery touches live under here.
PERIPHERY_ROOT_DIRECTORY=/etc/komodo
PERIPHERY_DISABLE_TERMINALS=false
PERIPHERY_DISABLE_CONTAINER_TERMINALS=false
PERIPHERY_INCLUDE_DISK_MOUNTS=/etc/hostname
PERIPHERY_LOGGING_PRETTY=false
PERIPHERY_PRETTY_STARTUP_CONFIG=false
