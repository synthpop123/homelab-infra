# Bundled reverse proxy for the Zitadel stack (the ONLY published port: 20031 -> :80).
# Akko terminates TLS and proxies https://auth.lkwplus.com -> fame:20031 (plain HTTP); this
# Caddy then does the path-split Zitadel v4 requires and the final h2c hop to the API:
#
#   /ui/v2/login/*  -> zitadel-login:3000   (Next.js Login V2 UI, HTTP/1.1)
#   everything else -> zitadel:8080 via h2c  (cleartext HTTP/2 — required for Zitadel's gRPC)
#
# Notes:
#   * X-Forwarded-Proto is forced to https: the public entrypoint (Akko) is https even though
#     this internal hop is plain http, and Zitadel must believe it is reached over https.
#   * Host is pinned to auth.lkwplus.com on the API hop so it always matches ZITADEL_EXTERNALDOMAIN
#     (a mismatch is the classic "Instance not found" error).
#   * `header_up -TE` strips the `TE: trailers` header, which otherwise makes error responses hang
#     (see zitadel.com/docs/self-hosting/manage/reverseproxy/caddy#known-issues).
{
	auto_https off
}

:80 {
	reverse_proxy /ui/v2/login/* http://zitadel-login:3000 {
		header_up X-Forwarded-Proto https
	}

	reverse_proxy h2c://zitadel:8080 {
		header_up Host auth.lkwplus.com
		header_up X-Forwarded-Proto https
		header_up -TE
	}
}
